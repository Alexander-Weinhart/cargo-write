[Desktop Entry]
Type=Application
Version=1.5
Name=Cargo Write
GenericName=Sticky notes
Comment=Write down notes, reminders, random thoughts and other short-term informations
Icon=io.github.cargowrite.CargoWrite
Exec=io.github.cargowrite.CargoWrite
Terminal=false
Actions=NewNote;Preferences;
Categories=Office;GTK;
Keywords=text;plain;plaintext;notepad;notes;sticky;post-it;
StartupNotify=true
SingleMainWindow=false

[Desktop Action NewNote]
Name=New sticky note
Icon=list-add
Exec=io.github.cargowrite.CargoWrite --new-note

[Desktop Action Preferences]
Name=Show Preferences
Icon=open-menu
Exec=io.github.cargowrite.CargoWrite --preferences
