<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
    <id>io.github.cargowrite.CargoWrite</id>
    <metadata_license>CC0-1.0</metadata_license>
    <project_license>GPL-3.0+</project_license>
    
    <name translate="no">Cargo Write</name>
    <summary>Write on colourful little squares</summary>
    <description>
        <p>Keep quick notes close at hand on colourful little squares.</p>
        <p>Features include:</p>
        <ul>
            <li>Colourful: Ten pretty themes. Any new note gets a random one</li>
            <li>Adaptive: New notes get the zoom you last chose</li>
            <li>Cute: Each new note has a funny or cute random (editable) title</li>
            <li>Handy: You can open links and emails with Ctrl+Click</li>
            <li>Private: Try the scribble mode!</li>
        </ul>
        <p>This project continues earlier community work on this style of note app.</p>
    </description>
    <launchable type="desktop-id">io.github.cargowrite.CargoWrite.desktop</launchable>

    <provides>
        <id>io.github.cargowrite.CargoWrite</id>
        <binary>io.github.cargowrite.CargoWrite</binary>
    </provides>
    <replaces>
        <id>io.github.cargowrite.CargoWrite</id>
    </replaces>

    <developer id="io.github.cargowrite">
        <name>Cargo Write contributors</name>
    </developer>

    <content_rating type="oars-1.1"/>
    <translation type="gettext" source_locale="en_GB">io.github.cargowrite.CargoWrite</translation>
    <branding>
      <color type="primary" scheme_preference="light">#64baff</color>
      <color type="primary" scheme_preference="dark">#002e99</color>
    </branding>
    <keywords>
        <keyword>Sticky notes</keyword>
        <keyword>Sticky note</keyword>
        <keyword>Stickies</keyword>
        <keyword>Colourful</keyword>
        <keyword>Notes</keyword>
        <keyword>Cute</keyword>
        <keyword>Desktop</keyword>
        <keyword>Reminder</keyword>
        <keyword>Utility</keyword>
        <keyword>Pantheon</keyword>
        <keyword>elementary OS</keyword>
    </keywords>
    <suggests>
        <id>io.github.cargowrite.reminduck</id>
        <id>com.github.elfenware.badger</id>
        <id>io.github.xchan14.larawan</id>
    </suggests>
    <recommends>
      <control>keyboard</control>
      <control>pointing</control>
      <control>touch</control>
    </recommends>
    <custom>
        <value key="x-appcenter-suggested-price">1</value>
    </custom>

    <releases>
        <release version="4.0.1" date="2026-01-13">
            <description>
                <p>Organization change</p>
            </description>
        </release>
        <release version="4.0.0" date="2025-11-22">
            <description>
                <p>🚀 4.0.0 Launch Update</p>
                <ul>
                    <li>Version 4 to align with Gtk version</li>
                    <li>Added button to toggle lists, and ability to customize them</li>
                    <li>Ctrl+Scroll to zoom-in, zoom-out</li>
                    <li>More zoom options</li>
                    <li>Keyboard shortcuts work from popover now</li>
                    <li>A couple visual bugfixes as well!</li>
                    <li>Various under the hood performance improvements</li>
                </ul>
            </description>
        </release>
        <release version="3.5.0" date="2025-11-06">
            <description>
                <p>Added windows build. It doesnt need admin rights. Mostly works.</p>
            </description>
        </release>
        <release version="3.4.1" date="2025-11-01">
            <description>
                <p>No fun allowed: revert back to default style</p>
            </description>
        </release>
        <release version="3.4.0" date="2025-09-30">
            <description>
                <p>🕷️ 3.4.0 Autumn Update</p>
                <ul>
                    <li>Some UI elements show up after being shown, for a sleek vibe</li>
                    <li>Ctrl+L to focus note title</li>
                    <li>Ctrl+G (For Gear) or Ctrl+O (for Open) to open note settings now</li>
                    <li>Alt+Number to change theme quickly</li>
                    <li>New note setting: Monospace (Ctrl+M). Could be for accessibility, could be for ascii doodles</li>
                    <li>Cleaner, nicer code under the hood. Probably marginally enhanced performances or less edge bugs</li>
                    <li>Added a reset-settings commandline option. Could be handy.</li>
                </ul>
            </description>
        </release>
        <release version="3.3.1" date="2025-07-12">
            <description>
                <ul>
                    <li>Bugfix: Fix Cargo Write lingering in the background not opening anymore if all windows were closed (#77)</li>
                </ul>
            </description>
        </release>
        <release version="3.3.0" date="2025-07-06">
            <description>
                <p>3.3.0 Interface Update</p>
                <ul>
                    <li>Bugfix: Whole window being grabbable interfered with text editing. Only actionbar and header are, now (#75, #76)</li>
                    <li>Added more random titles</li>
                    <li>Buttons for add/remove autostart</li>
                    <li>Some more title placeholders</li>
                    <li>Under the hood is a bit cleaner now</li>
                </ul>
            </description>
        </release>
        <release version="3.2.2" date="2025-06-05">
            <description>
                <p>Bugfix: When toggled off, the actionbar would leave an empty space. It is now fixed - With now a flashier animation to boot.</p>
            </description>
        </release>
        <release version="3.2.0" date="2025-06-03">
            <description>
                <p>🌈 3.2.0 Pride Update</p>
                <ul>
                    <li>Add a cool little animation when enabling/disabling actionbar</li>
                    <li>Fixed blurrinness in high-scaled display</li>
                    <li>Added high-resolution screenshots</li>
                    <li>Last minute bugfix, somehow accels did not work when the Preferences were focused</li>
                    <li>A bit of housekeeping for FR and DE while at it</li>
                </ul>
            </description>
        </release>
    </releases>   
</component>
