msgid "Sticky notes"
msgstr "Samolepicí poznámky"

#: data/cargo-write.desktop.in:7
msgid ""
"Write down notes, reminders, random thoughts and other short-term "
"informations"
msgstr ""
"Zapisujte si poznámky, připomínky, náhodné myšlenky a další krátkodobé "
"informace."

#: data/cargo-write.desktop.in:13
msgid "text;plain;plaintext;notepad;notes;sticky;post-it;"
msgstr "text;prostý;prostý text;poznámkový blok;poznámky;samolepicí;post-it;"

