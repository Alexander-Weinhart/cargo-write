#: data/cargo-write.desktop.in:5
msgid "Cargo Write"
msgstr "Cargo Write"

#: data/cargo-write.desktop.in:6 data/cargo-write.metainfo.xml.in:43
msgid "Sticky notes"
msgstr "Haftnotizen"

#: data/cargo-write.desktop.in:7
msgid ""
"Write down notes, reminders, random thoughts and other short-term "
"informations"
msgstr ""
"Notizen, Erinnerungen, zufällige Gedanken und andere kurzfristige "
"Informationen aufschreiben"

#: data/cargo-write.desktop.in:13
msgid "text;plain;plaintext;notepad;notes;sticky;post-it;"
msgstr "Text;einfach;Klartext;Notizblock;Notizen;Haftnotizen;Post-it;"

#: data/cargo-write.desktop.in:18
msgid "New sticky note"
msgstr "Neue Haftnotiz"

#: data/cargo-write.desktop.in:23
msgid "Show Preferences"
msgstr "Präferenzen anzeigen"

#: data/cargo-write.metainfo.xml.in:8
msgid "Write on colourful little squares"
msgstr "Schreibe auf bunte kleine Quadrate"

#: data/cargo-write.metainfo.xml.in:11
msgid "Features include:"
msgstr "Die Merkmale umfassen:"

#: data/cargo-write.metainfo.xml.in:13
msgid "Colourful: Ten pretty themes. Any new note gets a random one"
msgstr ""
"Farben: Zehn hübsche Themen. Jede neue Notiz erhält ein zufälliges Thema"

#: data/cargo-write.metainfo.xml.in:14
msgid "Adaptive: New notes get the zoom you last chose"
msgstr "Anpassungsfähig: Neue Notizen erhalten den zuletzt gewählten Zoom"

#: data/cargo-write.metainfo.xml.in:15
msgid "Cute: Each new note has a funny or cute random (editable) title"
msgstr ""
"Niedlich: Jede neue Notiz hat einen lustigen oder niedlichen, zufälligen "
"(editierbaren) Titel"

#: data/cargo-write.metainfo.xml.in:16
msgid "Handy: You can open links and emails with Ctrl+Click"
msgstr "Praktisch: Sie können Links und E-Mails mit Strg+Klick öffnen"

#: data/cargo-write.metainfo.xml.in:17
msgid "Private: Try the scribble mode!"
msgstr "Privat: Probieren Sie den Scribble-Modus aus!"

#: data/cargo-write.metainfo.xml.in:19
msgid ""
"This is a fork of an old version of \"Notejot\" by lainsce. The community "
"liked it so much, we thought it would be great to revive it!"
msgstr ""
"Dies ist ein Fork einer alten Version von \"Notejot\" von lainsce und würde "
"ohne ihre Arbeit nicht existieren. Die Community mochte sie so sehr, dass "
"wir dachten, es wäre toll, sie wiederzubeleben!"

#: data/cargo-write.metainfo.xml.in:27
msgid "Lainsce + Stella"
msgstr "Lainsce + Stella"

#: data/cargo-write.metainfo.xml.in:44
msgid "Sticky note"
msgstr "Haftnotizen"

#: data/cargo-write.metainfo.xml.in:45
msgid "Stickies"
msgstr "Haftnotizen"

#: data/cargo-write.metainfo.xml.in:46
msgid "Colourful"
msgstr "Buntes"

#: data/cargo-write.metainfo.xml.in:47
msgid "Notes"
msgstr "Anmerkungen"

#: data/cargo-write.metainfo.xml.in:48
msgid "Cute"
msgstr "Niedlich"

#: data/cargo-write.metainfo.xml.in:49
msgid "Desktop"
msgstr "Schreibtisch"

#: data/cargo-write.metainfo.xml.in:50
msgid "Reminder"
msgstr "Erinnerung"

#: data/cargo-write.metainfo.xml.in:51
msgid "Utility"
msgstr "Dienstprogramm"

#: data/cargo-write.metainfo.xml.in:52
msgid "Pantheon"
msgstr "Pantheon"

#: data/cargo-write.metainfo.xml.in:53
msgid "elementary OS"
msgstr "grundlegendes Betriebssystem"

#: data/cargo-write.metainfo.xml.in:71
msgid "A sticky note with the \"Blueberry\" theme"
msgstr "Eine Haftnotiz mit dem Thema \"Blaubeere\""

#: data/cargo-write.metainfo.xml.in:75
msgid ""
"Streaming? Worried of someone looking above your shoulder? Try the scribbly "
"Mode!"
msgstr ""
"Streaming? Haben Sie Angst, dass Ihnen jemand über die Schulter schaut? "
"Versuchen Sie den Scribbly-Modus!"

#: data/cargo-write.metainfo.xml.in:79
msgid "Look! Ascii art in a sticky note!"
msgstr "Schauen Sie! Ascii-Kunst auf einem Klebezettel!"

#: data/cargo-write.metainfo.xml.in:83
msgid "The preferences dialog in light mode"
msgstr "Der Einstellungsdialog im Lichtmodus"

#: data/cargo-write.metainfo.xml.in:87
msgid "The preferences dialog in dark mode"
msgstr "Der Einstellungsdialog im dunklen Modus"

#: data/cargo-write.metainfo.xml.in:95
#, fuzzy
msgid "🚀 4.0.0 Launch Update"
msgstr "3.0.0 Die Cargo Write des Donner"

